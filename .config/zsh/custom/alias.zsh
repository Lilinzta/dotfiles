# I just don't want that in my .zshrc
# It's so ugly
alias ap='~/Code/shell/ap.sh'
alias apr='sudo ifconfig ap0 down && sudo ifconfig ap0 up'
alias aq='asciiquarium'
alias c='cd'
alias ca='conda activate'
alias cC='sudo rm -rf ~/.cache/* && echo "Done!"'
alias du='du -h'
alias dpa='docker ps -a'
alias gh='cd ~ && clear'
alias glog='git log --pretty=oneline --all --graph --abbrev-commit'
alias gd='git diff'
alias hes='hexo clean && hexo g && hexo s'
alias hn='hexo new'
alias hd='hexo d'
alias hx='helix'
alias ig='ifconfig'
alias kcp='kdeconnect-cli -n V2048A --share'
alias kcw='kdeconnect-cli -n WayDroid x86_64 --share'
alias lf='ls | fzf'
alias lg='lazygit'
alias n='neofetch'
alias nv='nvim'
alias nvh='nvim ~/.histfile'
alias pa='mpv ~/Music/*'
alias sc='systemctl'
alias sl='ls'
alias sg='sgpt'
alias sga='sgpt --role assistant'
alias sgi='sgpt --repl tmp'
alias sgs='sgpt --repl shell --shell'
alias sgc='sudo rm -rf /tmp/shell_gpt && echo "Done!"'
alias sz='source ~/.zshrc'
alias sn='sudo nvim'
alias sura='sudo ranger .'
alias ts='sudo timeshift --create --tags D'
alias tsd='sudo timeshift --delete'
alias vu='systemctl start v2raya'
alias vd='systemctl stop v2raya'
